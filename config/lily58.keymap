#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>

/* ── Layer indices ─────────────────────────────────────────────────────── */
#define BASE       0
#define NAV        1
#define SYM        2
#define FN         3
#define JUMP       4
#define BOARD      5
#define MAC_MODE   6
#define NAV_MAC    7
#define JUMP_MAC   8
#define SPACE_MOD  9
#define BOARD_FAST 10
#define MOD        11

/* ── Fast mouse speed defines ──────────────────────────────────────────── */
#define FAST_UP MOVE_Y(-1800)
#define FAST_DN MOVE_Y(1800)
#define FAST_LT MOVE_X(-1800)
#define FAST_RT MOVE_X(1800)

/ {
  behaviors {
    #include "macros.dtsi"

    /* ── Tap-dances ──────────────────────────────────────────────────── */
    td_grave_tilde: td_grave_tilde {
      compatible = "zmk,behavior-tap-dance";
      #binding-cells = <0>;
      tapping-term-ms = <200>;
      bindings = <&kp GRAVE>, <&kp TILDE>;
    };
    td_equal_plus: td_equal_plus {
      compatible = "zmk,behavior-tap-dance";
      #binding-cells = <0>;
      tapping-term-ms = <200>;
      bindings = <&kp EQUAL>, <&kp PLUS>;
    };
    td_minus_under: td_minus_under {
      compatible = "zmk,behavior-tap-dance";
      #binding-cells = <0>;
      tapping-term-ms = <200>;
      bindings = <&kp MINUS>, <&kp UNDER>;
    };
    td_sqt_dqt: td_sqt_dqt {
      compatible = "zmk,behavior-tap-dance";
      #binding-cells = <0>;
      tapping-term-ms = <200>;
      bindings = <&kp SQT>, <&kp DQT>;
    };
    td_semi_colon: td_semi_colon {
      compatible = "zmk,behavior-tap-dance";
      #binding-cells = <0>;
      tapping-term-ms = <200>;
      bindings = <&kp SEMI>, <&kp COLON>;
    };

    /* ── Hold-tap safety behaviors ───────────────────────────────────── */
    ht_reset: ht_reset {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <1000>;
      flavor = "hold-preferred";
      bindings = <&sys_reset>, <&none>;
    };
    ht_boot: ht_boot {
      compatible = "zmk,behavior-hold-tap";
      #binding-cells = <2>;
      tapping-term-ms = <2000>;
      flavor = "hold-preferred";
      bindings = <&bootloader>, <&none>;
    };
  };

  /* ── Combos ──────────────────────────────────────────────────────────── */
  combos {
    compatible = "zmk,combos";
  };

  /* ── Conditional layers ──────────────────────────────────────────────── */
  conditional_layers {
    compatible = "zmk,conditional-layers";
    jump_cond {
      if-layers = <NAV SPACE_MOD>;
      then-layer = <JUMP>;
    };
    nav_mac_cond {
      if-layers = <NAV MAC_MODE>;
      then-layer = <NAV_MAC>;
    };
    jump_mac_cond {
      if-layers = <JUMP MAC_MODE>;
      then-layer = <JUMP_MAC>;
    };
    board_fast_cond {
      if-layers = <BOARD SPACE_MOD>;
      then-layer = <BOARD_FAST>;
    };
  };

  /* ── Keymap ──────────────────────────────────────────────────────────── */
  keymap {
    compatible = "zmk,keymap";

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 0 — BASE                                                  │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  `~   1    2    3    4    5        6    7    8    9    0   =+   │
     * │  TAB  Q    W    E    R    T        Y    U    I    O    P   -_   │
     * │  ESC  A    S    D    F    G        H    J    K    L   ;:   '"   │
     * │  LSF  Z    X    C    V    B  ×  ×  N    M   GUI  ALT CTL  RSF  │
     * │            BRD  SPC  NAV  ×        ×   MOD  SYM  FN            │
     * └─────────────────────────────────────────────────────────────────┘ */
    base_layer {
      display-name = "base";
      bindings = <
        &td_grave_tilde &kp N1 &kp N2 &kp N3 &kp N4 &kp N5      &kp N6 &kp N7 &kp N8 &kp N9 &kp N0 &td_equal_plus
        &kp TAB  &kp Q  &kp W  &kp E  &kp R  &kp T               &kp Y  &kp U  &kp I  &kp O  &kp P  &td_minus_under
        &kp ESC  &kp A  &kp S  &kp D  &kp F  &kp G               &kp H  &kp J  &kp K  &kp L  &td_semi_colon &td_sqt_dqt
        &kp LSFT &kp Z  &kp X  &kp C  &kp V  &kp B  &none &none  &kp N  &kp M  &kp LGUI &kp LALT &kp LCTRL &kp RSFT
                        &mo BOARD &kp SPACE &mo NAV &none           &none  &mo MOD &mo FN &mo SYM
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 1 — NAV (Windows default, WASD movement)                  │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___ HOME  ↑   END SelLn SelW     Redo ___  ___  ___  ___  ___ │
     * │ S-RET  ←    ↓    →  C-F  ___      ___ BSPC DEL  ___  ___  ___ │
     * │  LSF Undo Cut  Copy Pst  ___×  × ___ ___ C-Hm C-End ___ ___   │
     * │            ___  ___  ___  ×        × SMOD  ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    nav_layer {
      display-name = "nav";
      bindings = <
        &trans &trans   &trans  &trans  &trans             &trans                &trans    &trans   &trans  &trans  &trans  &trans
        &trans &kp HOME &kp UP &kp END &macro_sel_line_win &macro_sel_word_win  &Win_Redo &trans   &trans  &trans  &trans  &trans
        &kp LS(RET) &kp LEFT &kp DOWN &kp RIGHT &kp LC(F) &trans               &trans    &kp BSPC &kp DEL &trans  &trans  &trans
        &kp LSFT &Win_Undo &Win_Cut &Win_Copy &Win_Paste &trans &none &none    &kp LC(HOME) &kp LC(END) &trans &trans &trans &trans
                        &trans &trans &trans &none                                &none     &mo SPACE_MOD &trans  &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 2 — SYM (Karabiner bracket layout)                        │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___  !    @    #    $    %        ^    &    *    (    )    ___  │
     * │  ___  <    {    [    (    -        +    )    ]    }    >    ___  │
     * │  ___  |    \    /   ->    _        =   =>    ,    .    ?    ___  │
     * │  ___ ___  ___   ;    '    "  ×  ×  :   ___  ___  ___  ___  ___  │
     * │            ___  ___  ___  ×        ×   ___  ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    sym_layer {
      display-name = "sym";
      bindings = <
        &trans   &kp EXCL &kp AT   &kp HASH &kp DLLR          &kp PRCNT          &kp CARET &kp AMPS          &kp STAR  &kp LPAR &kp RPAR &trans
        &trans   &kp LT   &kp LBRC &kp LBKT &kp LPAR          &kp MINUS          &kp PLUS  &kp RPAR          &kp RBKT  &kp RBRC &kp GT   &trans
        &trans   &kp PIPE &kp BSLH &kp FSLH &macro_thin_arrow  &kp UNDER          &kp EQUAL &macro_fat_arrow_key &kp COMMA &kp DOT &kp QMARK &trans
        &trans   &trans   &trans   &kp SEMI &kp SQT            &kp DQT &none &none &kp COLON &trans           &trans    &trans   &trans   &trans
                          &trans   &trans   &trans              &none              &none     &trans            &trans    &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 3 — FN (Function keys, media, brightness)                 │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___  F1   F2   F3   F4   F5       F6   F7   F8   F9  F10  F11 │
     * │  ___ MUTE VOL+ ___  ___ Snip      ___  ___  ___  ___  ___  F12 │
     * │  ___ BRI- VOL- BRI+ ___  ___      ___ PREV PP  NEXT ___  F13  │
     * │  ___ ___  ___  ___  ___  ___×  × ___  ___  ___  ___  ___  ___  │
     * │            ___  ___  ___  ×        ×   ___  ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    fn_layer {
      display-name = "fn";
      bindings = <
        &trans &kp F1       &kp F2       &kp F3       &kp F4 &kp F5           &kp F6 &kp F7     &kp F8   &kp F9     &kp F10 &kp F11
        &trans &kp C_MUTE   &kp C_VOL_UP &trans       &trans &kp LG(LS(S))    &trans &trans      &trans   &trans     &trans  &kp F12
        &trans &kp C_BRI_DN &kp C_VOL_DN &kp C_BRI_UP &trans &trans           &trans &kp C_PREV  &kp C_PP &kp C_NEXT &trans  &kp F13
        &trans &trans       &trans       &trans       &trans &trans &none &none &trans &trans      &trans   &trans     &trans  &trans
                            &trans       &trans       &trans &none             &none  &trans      &trans   &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 4 — JUMP (conditional: NAV + SPACE_MOD)                   │
     * │ Word/page navigation. Falls through to NAV for unlisted keys.   │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___ ___  PgUp ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  RET C-←  PgDn C-→ CS-F  ___      ___ C-Bk C-Dl ___  ___  ___ │
     * │  ___ Redo ___  ___  ___  ___×  × ___  ___  ___  ___  ___  ___  │
     * │            ___  ___  ___  ×        ×   ___  ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    jump_layer {
      display-name = "jump";
      bindings = <
        &trans  &trans    &trans    &trans        &trans       &trans             &trans &trans      &trans     &trans &trans &trans
        &trans  &trans    &kp PG_UP &trans       &trans       &trans             &trans &trans      &trans     &trans &trans &trans
        &kp RET &kp LC(LEFT) &kp PG_DN &kp LC(RIGHT) &kp LC(LS(F)) &trans      &trans &kp LC(BSPC) &kp LC(DEL) &trans &trans &trans
        &trans  &Win_Redo &trans   &trans        &trans       &trans &none &none &trans &trans      &trans     &trans &trans &trans
                          &trans   &trans        &trans       &none              &none  &trans      &trans     &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 5 — BOARD (system, Bluetooth, mouse)                      │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___ BT0  BT1  BT2  BT3  BT4      ___  ___  ___  ___  ___ CLR │
     * │  ___ LCK  M↑  RCK  ___  ___      ___  ___  ___  ___  ___ OUT  │
     * │  ___  M←   M↓   M→  ___  ___      ___  ___  ___  ___  ___ STU │
     * │ BOOT RST  ___  ___  ___  ___×  × ___ MAC  ___  ___  ___ BOOT  │
     * │            ___  ___  ___  ×        × SMOD  ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    board_layer {
      display-name = "board";
      bindings = <
        &trans        &bt BT_SEL 0   &bt BT_SEL 1   &bt BT_SEL 2    &bt BT_SEL 3 &bt BT_SEL 4    &trans &trans        &trans &trans &trans &bt BT_CLR
        &trans        &mkp LCLK      &mmv MOVE_UP    &mkp RCLK       &trans       &trans           &trans &trans        &trans &trans &trans &out OUT_TOG
        &trans        &mmv MOVE_LEFT &mmv MOVE_DOWN  &mmv MOVE_RIGHT &trans       &trans           &trans &trans        &trans &trans &trans &studio_unlock
        &ht_boot 0 0  &ht_reset 0 0 &trans          &trans          &trans       &trans &none &none &trans &tog MAC_MODE &trans &trans &trans &ht_boot 0 0
                                     &trans          &trans          &trans &none           &none  &mo SPACE_MOD &trans &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 6 — MAC_MODE (empty flag layer, all transparent)          │
     * └─────────────────────────────────────────────────────────────────┘ */
    mac_mode_layer {
      display-name = "mac";
      bindings = <
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans &none &none &trans &trans &trans &trans &trans &trans
                      &trans &trans &trans &none       &none  &trans &trans &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 7 — NAV_MAC (conditional: NAV + MAC_MODE)                 │
     * │ Overrides NAV with Mac shortcuts (Cmd instead of Ctrl)          │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___  ___  ___ ___ SelLn SelW     Redo ___  ___  ___  ___  ___ │
     * │  ___  ___  ___  ___ ⌘F   ___      ___  ___  ___  ___  ___  ___ │
     * │  ___ ⌘Z  ⌘X   ⌘C   ⌘V   ___×  × ___  ___ ⌘↑   ⌘↓   ___  ___ │
     * │            ___  ___  ___  ×        ×   ___  ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    nav_mac_layer {
      display-name = "nav-mac";
      bindings = <
        &trans &trans     &trans   &trans    &trans          &trans              &trans    &trans &trans             &trans             &trans &trans
        &trans &trans     &trans   &trans    &macro_sel_line &macro_sel_word     &Mac_Redo &trans &trans             &trans             &trans &trans
        &trans &trans     &trans   &trans    &Mac_Find       &trans              &trans    &trans &trans             &trans             &trans &trans
        &trans &Mac_Undo  &Mac_Cut &Mac_Copy &Mac_Paste     &trans &none &none  &macro_doc_top_mac &macro_doc_bot_mac &trans &trans &trans &trans
                          &trans   &trans    &trans          &none               &none     &trans &trans             &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 8 — JUMP_MAC (conditional: JUMP + MAC_MODE)               │
     * │ Word nav with Option instead of Ctrl                            │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___ ⌥←   ___ ⌥→  ⌘⇧F   ___      ___ ⌥⌫   ⌥⌦   ___  ___  ___ │
     * │  ___ ⌘⇧Z  ___  ___  ___  ___×  × ___  ___  ___  ___  ___  ___  │
     * │            ___  ___  ___  ×        ×   ___  ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    jump_mac_layer {
      display-name = "jmp-mac";
      bindings = <
        &trans &trans    &trans &trans        &trans       &trans             &trans &trans      &trans     &trans &trans &trans
        &trans &trans    &trans &trans        &trans       &trans             &trans &trans      &trans     &trans &trans &trans
        &trans &kp LA(LEFT) &trans &kp LA(RIGHT) &kp LG(LS(F)) &trans       &trans &kp LA(BSPC) &kp LA(DEL) &trans &trans &trans
        &trans &Mac_Redo &trans &trans        &trans       &trans &none &none &trans &trans      &trans     &trans &trans &trans
                         &trans &trans        &trans       &none              &none  &trans      &trans     &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 9 — SPACE_MOD (helper layer, all transparent)             │
     * └─────────────────────────────────────────────────────────────────┘ */
    space_mod_layer {
      display-name = "smod";
      bindings = <
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans &none &none &trans &trans &trans &trans &trans &trans
                      &trans &trans &trans &none       &none  &trans &trans &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 10 — BOARD_FAST (conditional: BOARD + SPACE_MOD)          │
     * │ 3x mouse speed on WASD (hold pos 55 in BOARD layer)                                          │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___  ___ FM↑   ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___ FM←  FM↓  FM→   ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___  ___  ___  ___  ___  ___×  × ___  ___  ___  ___  ___  ___  │
     * │            ___  ___  ___  ×        ×   ___  ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    board_fast_layer {
      display-name = "brd-fst";
      bindings = <
        &trans &trans       &trans       &trans       &trans &trans             &trans &trans &trans &trans &trans &trans
        &trans &trans       &mmv FAST_UP &trans       &trans &trans             &trans &trans &trans &trans &trans &trans
        &trans &mmv FAST_LT &mmv FAST_DN &mmv FAST_RT &trans &trans            &trans &trans &trans &trans &trans &trans
        &trans &trans       &trans       &trans       &trans &trans &none &none &trans &trans &trans &trans &trans &trans
                            &trans       &trans       &trans &none              &none  &trans &trans &trans
      >;
    };

    /* ┌─────────────────────────────────────────────────────────────────┐
     * │ LAYER 11 — MOD (hold pos 55, modifier thumbs)                  │
     * │ Everything transparent except left thumb = Ctrl/Alt/Cmd         │
     * ├─────────────────────────────────────────────────────────────────┤
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___  ___  ___  ___  ___  ___      ___  ___  ___  ___  ___  ___ │
     * │  ___  ___  ___  ___  ___  ___×  × ___  ___  ___  ___  ___  ___  │
     * │           CTL  ALT  CMD  ×        ×   [MOD] ___  ___            │
     * └─────────────────────────────────────────────────────────────────┘ */
    mod_layer {
      display-name = "mod";
      bindings = <
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans      &trans &trans &trans &trans &trans &trans
        &trans &trans &trans &trans &trans &trans &none &none &trans &trans &trans &trans &trans &trans
                      &kp LCTRL &kp LALT &kp LGUI &none   &none  &trans &trans &trans
      >;
    };
  };
};
