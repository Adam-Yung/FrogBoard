  /* ── Auto-close bracket macros ─────────────────────────────────── */
  macro_quotes: macro_quotes {
    compatible = "zmk,behavior-macro";
    label = "MACRO_QUOTES";
    #binding-cells = <0>;
    bindings = <&kp SQT>, <&kp SQT>, <&kp LEFT>;
    display-name = "Auto ''";
  };
  macro_dquotes: macro_dquotes {
    compatible = "zmk,behavior-macro";
    label = "MACRO_DQUOTES";
    #binding-cells = <0>;
    bindings = <&kp DQT>, <&kp DQT>, <&kp LEFT>;
    display-name = "Auto \"\"";
  };
  macro_braces: macro_braces {
    compatible = "zmk,behavior-macro";
    label = "MACRO_BRACES";
    #binding-cells = <0>;
    bindings = <&kp LBRC>, <&kp RBRC>, <&kp LEFT>;
    display-name = "Auto {}";
  };
  macro_parens: macro_parens {
    compatible = "zmk,behavior-macro";
    label = "MACRO_PARENS";
    #binding-cells = <0>;
    bindings = <&kp LPAR>, <&kp RPAR>, <&kp LEFT>;
    display-name = "Auto ()";
  };
  macro_brackets: macro_brackets {
    compatible = "zmk,behavior-macro";
    label = "MACRO_BRACKETS";
    #binding-cells = <0>;
    bindings = <&kp LBKT>, <&kp RBKT>, <&kp LEFT>;
    display-name = "Auto []";
  };
  macro_angles: macro_angles {
    compatible = "zmk,behavior-macro";
    label = "MACRO_ANGLES";
    #binding-cells = <0>;
    bindings = <&kp LT>, <&kp GT>, <&kp LEFT>;
    display-name = "Auto <>";
  };
  macro_backticks: macro_backticks {
    compatible = "zmk,behavior-macro";
    label = "MACRO_BACKTICKS";
    #binding-cells = <0>;
    bindings = <&kp GRAVE>, <&kp GRAVE>, <&kp LEFT>;
    display-name = "Auto ``";
  };
  macro_triple_backtick: macro_triple_backtick {
    compatible = "zmk,behavior-macro";
    label = "MACRO_TRIPLE_BT";
    #binding-cells = <0>;
    bindings = <&kp GRAVE>, <&kp GRAVE>, <&kp GRAVE>, <&kp GRAVE>, <&kp GRAVE>, <&kp GRAVE>, <&kp LEFT>, <&kp LEFT>, <&kp LEFT>;
    display-name = "Auto ``` ```";
  };

  /* ── Text editing macros ────────────────────────────────────────── */
  macro_sel_word: macro_sel_word {
    compatible = "zmk,behavior-macro";
    label = "MACRO_SEL_WORD";
    #binding-cells = <0>;
    /* move right 1 char, jump to word start, select to word end */
    bindings = <&kp RIGHT>, <&kp LA(LEFT)>, <&kp LA(LS(RIGHT))>;
    display-name = "Select Word";
  };
  macro_sel_line: macro_sel_line {
    compatible = "zmk,behavior-macro";
    label = "MACRO_SEL_LINE";
    #binding-cells = <0>;
    /* jump to line start, select to line end */
    bindings = <&kp LG(LEFT)>, <&kp LG(LS(RIGHT))>;
    display-name = "Select Line";
  };

  /* ── Mac shortcuts ──────────────────────────────────────────────── */
  Mac_Cut: Mac_Cut {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(X)>;
    display-name = "Mac Cut";
  };
  Mac_Copy: Mac_Copy {
    compatible = "zmk,behavior-macro";
