  /* ── Auto-close bracket macros ─────────────────────────────────── */
  macro_quotes: macro_quotes {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp SQT>, <&kp SQT>, <&kp LEFT>;
  };
  macro_dquotes: macro_dquotes {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp DQT>, <&kp DQT>, <&kp LEFT>;
  };
  macro_braces: macro_braces {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LBRC>, <&kp RBRC>, <&kp LEFT>;
  };
  macro_parens: macro_parens {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LPAR>, <&kp RPAR>, <&kp LEFT>;
  };
  macro_brackets: macro_brackets {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LBKT>, <&kp RBKT>, <&kp LEFT>;
  };
  macro_angles: macro_angles {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LT>, <&kp GT>, <&kp LEFT>;
  };
  macro_backticks: macro_backticks {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp GRAVE>, <&kp GRAVE>, <&kp LEFT>;
  };
  macro_triple_backtick: macro_triple_backtick {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp GRAVE>, <&kp GRAVE>, <&kp GRAVE>, <&kp GRAVE>, <&kp GRAVE>, <&kp GRAVE>, <&kp LEFT>, <&kp LEFT>, <&kp LEFT>;
  };

  /* ── Text editing macros ────────────────────────────────────────── */
  macro_sel_word: macro_sel_word {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    /* move right 1 char, jump to word start, select to word end */
    bindings = <&kp RIGHT>, <&kp LA(LEFT)>, <&kp LA(LS(RIGHT))>;
  };
  macro_sel_line: macro_sel_line {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    /* jump to line start, select to line end */
    bindings = <&kp LG(LEFT)>, <&kp LG(LS(RIGHT))>;
  };

  /* ── Mac shortcuts ──────────────────────────────────────────────── */
  Mac_Cut: Mac_Cut {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(X)>;
  };
  Mac_Copy: Mac_Copy {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(C)>;
  };
  Mac_Paste: Mac_Paste {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(V)>;
  };
  Mac_Undo: Mac_Undo {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(Z)>;
  };
  Mac_Redo: Mac_Redo {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(LS(Z))>;
  };
  Mac_Select_All: Mac_SelAll {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(A)>;
  };
  Mac_Find: Mac_Find {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(F)>;
  };
  Mac_Mission_Control: Mac_MissionCtrl {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(UP)>;
  };
  Mac_Spotlight_Search: Mac_Spotlight {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(SPACE)>;
  };
  Mac_Snip_Tool: Mac_Snip {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(LG(LS(N4)))>;
  };
  Mac_Close_Program: Mac_Close {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(Q)>;
  };
  Mac_Strike_Through: Mac_Strike {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(LS(X))>;
  };
  Mac_Lock: Mac_Lock {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(LG(Q))>;
  };
  Mac_App_Switch: Mac_AppSwitch {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(TAB)>;
  };
  Mac_Win_Left: Mac_WinLeft {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(LEFT)>;
  };
  Mac_Win_Right: Mac_WinRight {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(RIGHT)>;
  };

  /* ── Windows shortcuts (kept for dual-OS use) ───────────────────── */
  Win_Cut: Windows_Cut {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(X)>;
  };
  Win_Copy: Windows_Copy {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(C)>;
  };
  Win_Paste: Windows_Paste {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(V)>;
  };
  Win_Undo: Windows_Undo {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(Z)>;
  };
  Win_Desktop: Win_Desk {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LG(D)>;
  };
  Win_Snip_Tool: Win_Snip {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LS(LG(S))>;
  };

  /* ── Mouse helpers ──────────────────────────────────────────────── */
  Double_Click: Double_Click {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&mkp MB1>, <&mkp MB1>;
  };

  /* ── Code digraph macros (used as SYM-layer combos) ─────────────── */
  macro_eq_eq: macro_eq_eq {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp EQUAL>, <&kp EQUAL>;
  };
  macro_not_eq: macro_not_eq {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp EXCL>, <&kp EQUAL>;
  };
  macro_fat_arrow: macro_fat_arrow {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp EQUAL>, <&kp GT>;
  };
  macro_arrow: macro_arrow {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp MINUS>, <&kp GT>;
  };
