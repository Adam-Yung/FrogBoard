  /* ── Windows shortcuts (kept for dual-OS use) ───────────────────── */
  Win_Cut: Windows_Cut {
    compatible = "zmk,behavior-macro";
    #binding-cells = <0>;
    bindings = <&kp LC(X)>;
    display-name = "Win Cut";
